<?xml version="1.0"?>
<robot name="two_robot_3d"
       xmlns:tesseract="http://tesseract-robotics.github.io/tesseract"
       tesseract:make_convex="true">

  <!-- ========================= -->
  <!-- World / base              -->
  <!-- ========================= -->

  <link name="base_link">
    <visual>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
      <geometry>
        <box size="2.5 1.5 0.02"/>
      </geometry>
      <material name="base_gray">
        <color rgba="0.6 0.6 0.6 0.25"/>
      </material>
    </visual>
  </link>

  <!-- ========================================================= -->
  <!-- Robot 1: three prismatic joints x/y/z                     -->
  <!-- Kinematic chain: base_link -> r1_link_x -> r1_link_y       -->
  <!--                  -> r1_link_z -> r1_robot_body            -->
  <!-- ========================================================= -->

  <link name="r1_link_x"/>

  <joint name="r1_joint_x" type="prismatic">
    <parent link="base_link"/>
    <child link="r1_link_x"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.0" upper="3.0" effort="1" velocity="1"/>
  </joint>

  <link name="r1_link_y"/>

  <joint name="r1_joint_y" type="prismatic">
    <parent link="r1_link_x"/>
    <child link="r1_link_y"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.0" upper="2.0" effort="1" velocity="1"/>
  </joint>

  <link name="r1_link_z"/>

  <joint name="r1_joint_z" type="prismatic">
    <parent link="r1_link_y"/>
    <child link="r1_link_z"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.0" upper="1.0" effort="1" velocity="1"/>
  </joint>

  <link name="r1_robot_body">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.10"/>
      </geometry>
      <material name="robot1_blue">
        <color rgba="0.1 0.3 1.0 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.10"/>
      </geometry>
    </collision>
  </link>

  <joint name="r1_body_joint" type="fixed">
    <parent link="r1_link_z"/>
    <child link="r1_robot_body"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ========================================================= -->
  <!-- Robot 2: three prismatic joints x/y/z                     -->
  <!-- Kinematic chain: base_link -> r2_link_x -> r2_link_y       -->
  <!--                  -> r2_link_z -> r2_robot_body            -->
  <!-- ========================================================= -->

  <link name="r2_link_x"/>

  <joint name="r2_joint_x" type="prismatic">
    <parent link="base_link"/>
    <child link="r2_link_x"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.0" upper="3.0" effort="1" velocity="1"/>
  </joint>

  <link name="r2_link_y"/>

  <joint name="r2_joint_y" type="prismatic">
    <parent link="r2_link_x"/>
    <child link="r2_link_y"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.0" upper="2.0" effort="1" velocity="1"/>
  </joint>

  <link name="r2_link_z"/>

  <joint name="r2_joint_z" type="prismatic">
    <parent link="r2_link_y"/>
    <child link="r2_link_z"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.0" upper="1.0" effort="1" velocity="1"/>
  </joint>

  <link name="r2_robot_body">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.10"/>
      </geometry>
      <material name="robot2_orange">
        <color rgba="1.0 0.45 0.1 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.10"/>
      </geometry>
    </collision>
  </link>

  <joint name="r2_body_joint" type="fixed">
    <parent link="r2_link_z"/>
    <child link="r2_robot_body"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

</robot>